    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.9",
    "prisma": "^7.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
