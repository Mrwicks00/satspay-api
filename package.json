  },
  "homepage": "https://github.com/Mrwicks00/satspay-api#readme",
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
