{
  "name": "satspay-api",
  "version": "1.0.0",
  "description": "The backend API powering the SatsPay protocol. Built with Node.js and Express, it sits between the frontend and the Stacks blockchain — handling authentication, transaction orchestration, claim management, FX rates, SMS notifications, and NGN offramp payouts.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
